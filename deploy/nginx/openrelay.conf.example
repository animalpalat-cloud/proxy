# OpenRelay — Nginx reverse proxy (Ubuntu)
# Replace YOUR_DOMAIN and paths, then:
#   sudo cp deploy/nginx/openrelay.conf.example /etc/nginx/sites-available/openrelay
#   sudo ln -s /etc/nginx/sites-available/openrelay /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Architecture: Next.js (port 3000) is the SOLE public face. It reverse-proxies
# /bare/* internally to the Rust bare server bound to 127.0.0.1:8000 via
# my-app/middleware.ts. Do NOT add a /bare → Rust shortcut here — that would
# bypass middleware.ts's structured error responses and re-introduce the
# trailing-slash / 308 problems.

# Required for ws/wss upgrade pass-through on the catch-all location.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream openrelay_next {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;  # e.g. daddyproxy.com www.daddyproxy.com

    # After certbot: listen 443 ssl; and ssl_certificate directives

    client_max_body_size 2m;

    # Everything (including /bare) → Next.js. Next handles /bare via middleware.ts.
    location / {
        proxy_pass http://openrelay_next;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_buffering off;
    }
}
