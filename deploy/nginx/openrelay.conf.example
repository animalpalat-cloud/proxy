# OpenRelay — Nginx reverse proxy (Ubuntu)
# Replace YOUR_DOMAIN and paths, then:
#   sudo cp deploy/nginx/openrelay.conf.example /etc/nginx/sites-available/openrelay
#   sudo ln -s /etc/nginx/sites-available/openrelay /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

upstream openrelay_next {
    server 127.0.0.1:3000;
    keepalive 32;
}

upstream openrelay_api {
    server 127.0.0.1:8000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    # After certbot: listen 443 ssl; and ssl_certificate directives

    client_max_body_size 2m;

    # Next.js frontend
    location / {
        proxy_pass http://openrelay_next;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    # Express API (unblock + proxy stream)
    location /api/ {
        proxy_pass http://openrelay_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_buffering off;
    }
}

# Optional: API on a subdomain (api.YOUR_DOMAIN) instead of /api on the main host
# server {
#     listen 80;
#     server_name api.YOUR_DOMAIN;
