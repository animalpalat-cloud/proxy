# OpenRelay — https://daddyproxy.com
# sudo cp deploy/nginx/daddyproxy.com.conf.example /etc/nginx/sites-available/daddyproxy
# sudo ln -sf /etc/nginx/sites-available/daddyproxy /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx
#
# Architecture: Next.js (port 3000) is the SOLE public face. It reverse-proxies
# /bare/* internally to the Rust bare server bound to 127.0.0.1:8000 via
# my-app/middleware.ts. Nginx therefore sends EVERYTHING (including /bare) to
# Next.js — there is intentionally no /bare → Rust shortcut here, because a
# shortcut would (a) bypass middleware.ts's structured error responses, (b)
# turn any Rust hiccup into a Cloudflare/Nginx 502 HTML page that the bare-mux
# client can't parse, and (c) re-introduce the trailing-slash / 308 issues we
# spent the last debugging cycles eliminating.

# Required for ws/wss upgrade pass-through on the catch-all location.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream openrelay_next {
    server 127.0.0.1:3000;
    keepalive 32;
}

# HTTP -> HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name daddyproxy.com www.daddyproxy.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name daddyproxy.com www.daddyproxy.com;

    # certbot --nginx -d daddyproxy.com -d www.daddyproxy.com
    ssl_certificate     /etc/letsencrypt/live/daddyproxy.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/daddyproxy.com/privkey.pem;

    client_max_body_size 4m;

    # Everything (including /bare) → Next.js. Next handles /bare via middleware.ts.
    location / {
        proxy_pass http://openrelay_next;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_buffering off;  # let bare streaming responses flow chunk-by-chunk
    }
}
