# OpenRelay — https://daddyproxy.com
# sudo cp deploy/nginx/daddyproxy.com.conf.example /etc/nginx/sites-available/daddyproxy
# sudo ln -sf /etc/nginx/sites-available/daddyproxy /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx

upstream openrelay_next {
    server 127.0.0.1:3000;
    keepalive 32;
}

upstream openrelay_bare {
    server 127.0.0.1:8000;
    keepalive 32;
}

# HTTP -> HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name daddyproxy.com www.daddyproxy.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name daddyproxy.com www.daddyproxy.com;

    # certbot --nginx -d daddyproxy.com -d www.daddyproxy.com
    ssl_certificate     /etc/letsencrypt/live/daddyproxy.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/daddyproxy.com/privkey.pem;

    client_max_body_size 4m;

    # Next.js frontend
    location / {
        proxy_pass http://openrelay_next;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # TompHTTP Bare (Rust) — match /bare and /bare/ without redirect (bare-mux uses /bare)
    location = /bare {
        proxy_pass http://openrelay_bare/bare/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_buffering off;
    }

    location /bare/ {
        proxy_pass http://openrelay_bare;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_buffering off;
    }
}
