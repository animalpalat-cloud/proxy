# Local development — copy to server/.env
NODE_ENV=development
PORT=8000
BIND_HOST=127.0.0.1

API_PUBLIC_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:3000

IPROYAL_HOST=unblocker.iproyal.com
IPROYAL_PORT=12323
IPROYAL_USERNAME=your_username
IPROYAL_PASSWORD=your_password
IPROYAL_SCHEME=http
IPROYAL_TLS_INSECURE=true
IPROYAL_MAX_RETRIES=3
