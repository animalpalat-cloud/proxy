# =============================================================================
# OpenRelay API — copy to .env and fill in (never commit .env)
# =============================================================================

NODE_ENV=production
PORT=8000
BIND_HOST=127.0.0.1

# Public URL browsers use for proxy tabs (no trailing slash)
# Production: https://api.yourdomain.com  OR  https://yourdomain.com if Nginx serves /api here
API_PUBLIC_URL=https://api.yourdomain.com

# Comma-separated origins allowed by CORS (your Next.js site)
FRONTEND_URL=https://yourdomain.com

# ---------------------------------------------------------------------------
# IPRoyal Web Unblocker (hostname only — NOT geo.iproyal.com)
# Connection string: http://USERNAME:PASSWORD@unblocker.iproyal.com:12323
# ---------------------------------------------------------------------------
IPROYAL_HOST=unblocker.iproyal.com
IPROYAL_PORT=12323
IPROYAL_USERNAME=your_iproyal_username
IPROYAL_PASSWORD=your_iproyal_password
IPROYAL_SCHEME=http

# Required for Web Unblocker MITM TLS (do not set false unless you know why)
IPROYAL_TLS_INSECURE=true

# Region rotation: us → gb → de → fr → ca → es (max 3 attempts per request)
IPROYAL_APPEND_COUNTRY=true
IPROYAL_REGION_FAILOVER=true
# Max region attempts per request (1 initial + 1 failover = 2)
IPROYAL_MAX_REGION_FAILOVER=2
IPROYAL_RETRY_DELAY_MS=800
IPROYAL_PROBE_TIMEOUT_MS=45000
IPROYAL_REQUEST_TIMEOUT_MS=90000

# Optional: desktop User-Agent (default is Chrome on Windows)
# IPROYAL_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ...

# Optional: _country-us / _country-gb / _country-de suffix on username
# IPROYAL_APPEND_COUNTRY=false
