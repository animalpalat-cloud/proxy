# =============================================================================
# OpenRelay API — copy to .env (never commit .env)
# =============================================================================

NODE_ENV=development
PORT=8000
BIND_HOST=127.0.0.1

# Public URL browsers use (no trailing slash)
API_PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# Production example:
# FRONTEND_URL=https://daddyproxy.com,https://www.daddyproxy.com

# ---------------------------------------------------------------------------
# ProxySeller HTTP proxy (Thailand auto-rotate — no _c_XX suffix by default)
# Whitelist your machine's public IP in the ProxySeller dashboard.
# ---------------------------------------------------------------------------
PROXYSELLER_HOST=148.113.49.124
PROXYSELLER_HTTP_PORT=41093
PROXYSELLER_SOCKS_PORT=51093
PROXYSELLER_USERNAME=your_proxy_login
PROXYSELLER_PASSWORD=your_proxy_password
PROXYSELLER_SCHEME=http

# Your public IP as registered in ProxySeller (reference — whitelist in dashboard)
PROXYSELLER_AUTH_IP=116.71.185.232

# false = dedicated/rotating login without country suffix (recommended for this setup)
PROXYSELLER_APPEND_COUNTRY=false
PROXYSELLER_TLS_INSECURE=true
PROXYSELLER_PROBE_TIMEOUT_MS=45000
PROXYSELLER_REQUEST_TIMEOUT_MS=90000
PROXYSELLER_RETRY_DELAY_MS=800

# Transport: auto (tunnel then hpa ladder) | tunnel | hpa
PROXYSELLER_TRANSPORT=auto
# Force HTTP/1.1 ALPN on destination TLS (set false if handshake fails)
PROXYSELLER_ALPN_HTTP1_ONLY=true
PROXYSELLER_KEEP_ALIVE=true
# Verbose proxy socket/TLS logs in terminal
PROXY_DEBUG=false

# Optional desktop User-Agent override
# PROXYSELLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ...
