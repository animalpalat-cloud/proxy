# Copy to server/.env on the VPS (never commit real .env)

NODE_ENV=production
PORT=8000
BIND_HOST=127.0.0.1

# Public site URL (no trailing slash) — used for viewer links and CORS
API_PUBLIC_URL=https://daddyproxy.com
# Comma-separated — include apex + www for CORS
FRONTEND_URL=https://daddyproxy.com,https://www.daddyproxy.com

# ProxySeller — whitelist the VPS public IP in the dashboard
PROXYSELLER_HOST=your_proxy_host
PROXYSELLER_HTTP_PORT=41093
PROXYSELLER_USERNAME=your_username
PROXYSELLER_PASSWORD=your_password
PROXYSELLER_SCHEME=http
PROXYSELLER_AUTH_IP=your_vps_public_ip
PROXYSELLER_TLS_INSECURE=true
PROXYSELLER_TRANSPORT=auto
PROXYSELLER_ALPN_HTTP1_ONLY=true
PROXYSELLER_KEEP_ALIVE=true
PROXY_DEBUG=false
