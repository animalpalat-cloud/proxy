# openrelay-bare is INTERNAL-ONLY. Next.js (port 3000) is the public face
# and reverse-proxies /bare/* to this server at 127.0.0.1:8000. Do NOT
# expose this port publicly. The server refuses to bind anything but the
# loopback interface for that reason.
BIND_HOST=127.0.0.1
PORT=8000
RUST_LOG=info,openrelay_bare=debug

# ProxySeller mobile — SOCKS5 upstream (native transport)
PROXYSELLER_HOST=148.113.49.124
PROXYSELLER_SOCKS_PORT=51093
PROXYSELLER_HTTP_PORT=41093
PROXYSELLER_USERNAME=
PROXYSELLER_PASSWORD=
# Dashboard whitelist (VPS outbound IPs; not sent on the wire)
PROXYSELLER_AUTH_IPS=

# Destination TLS through SOCKS (upstream sites)
PROXYSELLER_TLS_INSECURE=true
PROXYSELLER_ALPN_HTTP1_ONLY=true
PROXYSELLER_KEEP_ALIVE=true

PROXY_REQUEST_TIMEOUT_SECS=120
PROXY_CONNECT_TIMEOUT_SECS=30
PROXY_RETRY_ON_RESET=true
PROXY_RETRY_DELAY_MS=800
